<site xmlns="http://maven.apache.org/SITE/2.1.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/SITE/2.1.0 https://maven.apache.org/xsd/site-2.1.0.xsd"
    name="${project.name}">

    <skin>
        <groupId>org.apache.maven.skins</groupId>
        <artifactId>maven-fluido-skin</artifactId>
        <version>${fludioVersion}</version>
    </skin>

    <custom>
        <fluidoSkin>
            <gitHub>
                <projectId>weblegacy/tiles-jakarta</projectId>
                <ribbonOrientation>right</ribbonOrientation>
                <ribbonColor>darkblue</ribbonColor>
            </gitHub>
        </fluidoSkin>
    </custom>

    <bannerLeft
        name="Apache Software Foundation"
        href="https://www.apache.org/">

        <image src="images/asf-logo.png" />
    </bannerLeft>

    <bannerRight name="Apache Tiles&#8482;"
        href="https://tiles.apache.org">

        <image src="images/tiles.png" />
    </bannerRight>

    <body>
        <links>
            <item name="${project.name}" href="${project.url}" />
        </links>

        <menu name="Apache Tiles &#8482;">
            <item name="Tiles Home" href="https://tiles.apache.org/index.html" />
            <item name="Apache Tiles 2" href="https://tiles.apache.org/2.2/framework/index.html" />
            <item name="Apache Tiles 3" href="https://tiles.apache.org/framework/index.html" />
        </menu>

        <menu name="Documentation">
            <item name="Welcome" href="index.html" />
            <item name="Changes" href="changes-report.html" />
            <item name="Javadoc" href="apidocs/index.html" />
            <item name="Releases" href="https://github.com/weblegacy/tiles-jakarta/releases" />
        </menu>

        <menu ref="parent" />
        <menu ref="modules" />
        <menu ref="reports" />
    </body>
</site>
